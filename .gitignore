# Shadow of the Colossus & PCSX2 Gitignore (Gold Standard)

# ---------------------------------------------------------
# BLOQUEIO GLOBAL (Binários, Temporários e Caches)
# ---------------------------------------------------------
*.iso
*.iso.*
*.bin
*.chd
*.gz
*.cso
*.mdf
*.tmp
*.log
*.bak
*.old
*.png
*.jpg
*.jpeg
*.webp
*.zip
*.rar
*.7z
*.tar

# ---------------------------------------------------------
# PASTAS DE SUPORTE E SISTEMA (Ignorar Completamente)
# ---------------------------------------------------------
/PS2/
/lab/
/flatpak/
/doc/
/.agents/
/lost+found/
/.Trash-*/
/ps2_bios/
/RetroArch/
/aquiArquivo/
/resuperandoAmerdaque*/

# ---------------------------------------------------------
# DADOS DINÂMICOS DO EMULADOR (PCSX2-Userdata)
# ---------------------------------------------------------
# Ignora tudo dentro de pcsx2-userdata por padrão
pcsx2-userdata/

# Exceto a estrutura de pastas que queremos (Whitelisting reverso)
!pcsx2-userdata/
!pcsx2-userdata/**/

# ---------------------------------------------------------
# BLOQUEIO DE DADOS PESADOS (Exceções ao whitelist acima)
# ---------------------------------------------------------
# Pastas de Cache e Texturas
**/Texturas/
**/textures/
**/replacements/
**/previews/
**/cache/
**/vulkan_shaders/
**/vulkan_pipelines/
**/BACKUP_SOTC_*/

# Dados Voláteis do Emulador
**/sstates/
**/logs/
**/snaps/
**/translations/
**/bios/
**/covers/
**/patches/
**/debuggerlayouts/
**/pulse/
**/.ld.so/
**/QtProject.conf
**/playtime.dat

# ---------------------------------------------------------
# WHITELIST: CONFIGURAÇÕES E CHEATS (O que queremos rastrear)
# ---------------------------------------------------------
# Bloqueia memory cards em formato antigo (.ps2, .psu, etc)
**/memcards/*.ps2
**/memcards/*.psu
**/memcards/*.cbs
**/memcards/*.max

# Permite explicitamente os arquivos de texto e pastas de memcard
!*.pnach
!*.sh
!*.py
!*.md
!*.ini
!**/config/**/*.ini
!**/cheats/*.pnach
!**/patches/*.pnach
!**/memcards/*/
!**/memcards/*/.gitkeep
# ---------------------------------------------------------
# RPCS3
# ---------------------------------------------------------
/rpcs3/